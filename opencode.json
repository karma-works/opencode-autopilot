{
  "plugin": ["opencode-autopilot"],
  "agent": {
    "auto": {
      "systemPrompt": ".opencode/modes/auto.md",
      "tools": {
        "allow": ["*"],
        "deny": []
      }
    }
  },
  "autoMode": {
    "maxSteps": 100,
    "timeoutMinutes": 30,
    "writableRoots": ["."],
    "allowedNetworkHosts": [],
    "bashFastScreen": false,
    "judgeIncludeRemoteOutputs": false,
    "judge": {
      "provider": null,
      "model": null
    }
  }
}
